# ============================================================================
# Copy this file to `.env` (which is git-ignored) and fill in your values.
#   cp .env.example .env
#
# The bootstrap script (`npm run bootstrap`) will AUTO-FILL the two SDK keys
# (LD_SDK_KEY and VITE_LD_CLIENT_ID) for you by reading them from the
# LaunchDarkly API — so you normally only need to provide LD_API_TOKEN,
# the project/env keys, and ANTHROPIC_API_KEY.
# ============================================================================

# --- LaunchDarkly: management API (used ONLY by scripts/, never shipped) -----
# Create at: LaunchDarkly > Account settings > Authorization > Create token.
# Needs a Writer (or Admin) role so it can create flags, segments, metrics,
# and triggers. Starts with "api-".
LD_API_TOKEN=api-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# The LaunchDarkly project + environment the demo runs against.
# The bootstrap script creates the project if it does not already exist.
LD_PROJECT_KEY=se-exercise
LD_ENV_KEY=production

# --- LaunchDarkly: SDK keys (auto-filled by `npm run bootstrap`) -------------
# Server-side SDK key for the Node backend. Starts with "sdk-".
LD_SDK_KEY=

# Client-side ID for the browser (React) SDK. This is PUBLIC by design and
# safe to expose to the browser. Vite only exposes vars prefixed with VITE_.
VITE_LD_CLIENT_ID=

# --- Anthropic (AI Configs extra credit) ------------------------------------
# Create at: https://console.anthropic.com/ . Starts with "sk-ant-".
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Local server config -----------------------------------------------------
PORT=3001
